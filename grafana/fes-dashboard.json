    {
      "title": "Kafka Messages Total (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 1000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum(fes_kafka_messages_total)",
          "legendFormat": "Total messages",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Kafka Messages Total (by Topic)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
